<?xml version="1.0"?>
<yandex>
    <logger>
        <level>information</level>
        <console>true</console>
    </logger>
    <max_concurrent_queries>100</max_concurrent_queries>
    <max_insert_block_size>1048576</max_insert_block_size>

    <merge_tree>
        <max_suspicious_broken_parts>10</max_suspicious_broken_parts>
        <parts_to_delay_insert>300</parts_to_delay_insert>
        <max_number_of_merges_with_ttl_in_pool>10</max_number_of_merges_with_ttl_in_pool>
        <allow_remote_fs_zero_copy_replication>0</allow_remote_fs_zero_copy_replication>
    </merge_tree>

    <compression>
        <case>
            <min_part_size>10485760</min_part_size>
            <min_part_size_ratio>0.01</min_part_size_ratio>
            <method>zstd</method>
            <level>3</level>
        </case>
    </compression>

    <profiles>
        <default>
            <load_balancing>random</load_balancing>
            <max_memory_usage>10000000000</max_memory_usage>
            <max_threads>8</max_threads>
        </default>
        <readonly>
            <readonly>1</readonly>
        </readonly>
    </profiles>

    <users>
        <default>
            <password from_env="CLICKHOUSE_PASSWORD"></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
    </users>

    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</yandex>
